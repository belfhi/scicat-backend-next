{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "desy": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "DESY",
            "options": {
                "baseURL": "https://assistant.desy.de/api/",
                "apiKey": "{env:DESY_ASSISTANT_API_KEY}"
            },
            "models": {
                "coding": {
                    "name": "DESY Assistant Coding",
                    "limit": {
                        "context": 1048576,
                        "output": 384000
                    }
                }
            }
        }
    }
}